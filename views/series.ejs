<%- include('partials/head') %>
<%- include('partials/nav') %>

<main class="max-w-6xl mx-auto px-4 py-6 flex-1">
  <h1 class="text-xl md:text-2xl font-bold text-zinc-100 mb-6"><%= title %></h1>

  <input type="text" id="search-serie" placeholder="Rechercher une série..."
         class="bg-zinc-900 border border-zinc-700 rounded px-3 py-2 text-sm text-zinc-200 placeholder-zinc-500 focus:outline-none focus:border-amber-600 w-full sm:w-64 mb-6">

  <% if (sortedKeys.length === 0) { %>
    <p class="text-zinc-500 text-center py-12">Aucune série.</p>
  <% } else { %>
    <div class="space-y-4">
      <% for (const serie of sortedKeys) { %>
        <% const tomes = grouped[serie]; %>
        <% const owned = tomes.filter(t => t.status === 'owned' || t.status === 'owned_no_hs').length; %>
        <% const total = tomes.length; %>
        <% const pct = total > 0 ? Math.round((owned / total) * 100) : 0; %>
        <% const note = serieNotes[serie] || ''; %>
        <details class="serie-block bg-zinc-900/50 border border-zinc-800 rounded-lg" data-serie="<%= serie.toLowerCase() %>">
          <summary class="px-3 md:px-4 py-3 cursor-pointer hover:bg-zinc-800/50 rounded-lg transition-colors">
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-2 md:gap-3 min-w-0">
                <span class="font-medium text-zinc-100 text-sm md:text-base truncate"><%= serie %></span>
                <span class="text-xs text-zinc-500 flex-shrink-0"><%= owned %>/<%= total %></span>
                <% if (note) { %>
                  <span class="text-xs text-zinc-600 hidden md:inline" title="<%= note %>">&#128221;</span>
                <% } %>
              </div>
              <div class="flex items-center gap-2 md:gap-3 flex-shrink-0 ml-2">
                <div class="w-16 md:w-32 h-1.5 bg-zinc-800 rounded-full overflow-hidden">
                  <div class="h-full rounded-full transition-all
                    <%= pct === 100 ? 'bg-emerald-500' : pct > 50 ? 'bg-amber-500' : 'bg-red-500' %>"
                    style="width: <%= pct %>%"></div>
                </div>
                <span class="text-xs text-zinc-500 w-8 text-right"><%= pct %>%</span>
              </div>
            </div>
          </summary>
          <div class="px-3 md:px-4 pb-3">

            <!-- Serie note -->
            <div class="mb-3 mt-1">
              <div class="flex items-center gap-2 mb-1">
                <span class="text-xs text-zinc-500">Note sur la série</span>
              </div>
              <textarea class="serie-note-input w-full bg-zinc-900 border border-zinc-800 rounded px-3 py-1.5 text-xs text-zinc-300 focus:outline-none focus:border-amber-600 resize-none"
                        rows="2" placeholder="Notes sur cette série..." data-serie="<%= serie %>"><%= note %></textarea>
            </div>

            <!-- Desktop table -->
            <table class="hidden md:table w-full text-sm">
              <% for (const bd of tomes) { %>
                <tr class="border-t border-zinc-800/50">
                  <td class="py-2 pr-3 w-10">
                    <% if (bd.cover_url) { %>
                      <img src="<%= bd.cover_url %>" alt="" class="w-8 h-11 object-cover rounded" loading="lazy">
                    <% } else { %>
                      <div class="w-8 h-11 bg-zinc-800 rounded flex items-center justify-center">
                        <svg class="w-4 h-4 text-zinc-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
                      </div>
                    <% } %>
                  </td>
                  <td class="py-2 pr-4 w-12 text-center text-zinc-500"><%= bd.numero != null ? bd.numero : '-' %></td>
                  <td class="py-2 pr-4 text-zinc-300"><%= bd.titre %></td>
                  <td class="py-2 pr-4">
                    <select class="status-select bg-transparent border border-zinc-700 rounded px-2 py-1 text-xs focus:outline-none focus:border-amber-600
                      <%= bd.status === 'owned' || bd.status === 'owned_no_hs' ? 'text-emerald-400' : '' %>
                      <%= bd.status === 'missing' ? 'text-red-400' : '' %>
                      <%= bd.status === 'in_progress' ? 'text-amber-400' : '' %>
                      <%= bd.status === 'not_owned' ? 'text-zinc-500' : '' %>"
                      data-id="<%= bd.id %>">
                      <% for (const s of statuses) { %>
                        <option value="<%= s.value %>" <%= bd.status === s.value ? 'selected' : '' %>><%= s.label %></option>
                      <% } %>
                    </select>
                  </td>
                  <td class="py-2 pr-4 text-zinc-500 text-xs"><%= bd.commentaire || '' %></td>
                  <td class="py-2 text-right">
                    <% if (bd.web_tracking) { %>
                      <a href="<%= bd.web_tracking %>" target="_blank" rel="noopener" class="text-amber-500 hover:text-amber-400 text-xs mr-2">&#8599;</a>
                    <% } %>
                    <a href="/edit/<%= bd.id %>" class="text-zinc-500 hover:text-zinc-300 text-xs">Modifier</a>
                  </td>
                </tr>
              <% } %>
            </table>

            <!-- Mobile list -->
            <div class="md:hidden space-y-2">
              <% for (const bd of tomes) { %>
                <div class="flex gap-2.5 py-2 border-t border-zinc-800/50">
                  <div class="flex-shrink-0">
                    <% if (bd.cover_url) { %>
                      <img src="<%= bd.cover_url %>" alt="" class="w-10 h-14 object-cover rounded" loading="lazy">
                    <% } else { %>
                      <div class="w-10 h-14 bg-zinc-800 rounded flex items-center justify-center">
                        <svg class="w-4 h-4 text-zinc-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
                      </div>
                    <% } %>
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-start justify-between">
                      <div class="min-w-0">
                        <p class="text-sm text-zinc-200 truncate"><%= bd.titre %></p>
                        <p class="text-xs text-zinc-500"><%= bd.numero != null ? '#' + bd.numero : '' %></p>
                      </div>
                      <a href="/edit/<%= bd.id %>" class="text-zinc-500 text-xs flex-shrink-0 ml-2">Modifier</a>
                    </div>
                    <select class="status-select mt-1 bg-transparent border border-zinc-700 rounded px-2 py-1 text-xs focus:outline-none focus:border-amber-600
                      <%= bd.status === 'owned' || bd.status === 'owned_no_hs' ? 'text-emerald-400' : '' %>
                      <%= bd.status === 'missing' ? 'text-red-400' : '' %>
                      <%= bd.status === 'in_progress' ? 'text-amber-400' : '' %>
                      <%= bd.status === 'not_owned' ? 'text-zinc-500' : '' %>"
                      data-id="<%= bd.id %>">
                      <% for (const s of statuses) { %>
                        <option value="<%= s.value %>" <%= bd.status === s.value ? 'selected' : '' %>><%= s.label %></option>
                      <% } %>
                    </select>
                  </div>
                </div>
              <% } %>
            </div>
          </div>
        </details>
      <% } %>
    </div>
  <% } %>
</main>

<%- include('partials/foot') %>
