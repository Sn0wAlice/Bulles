<%- include('partials/head') %>
<%- include('partials/nav') %>

<main class="max-w-6xl mx-auto px-4 py-6 flex-1">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-xl md:text-2xl font-bold text-zinc-100"><%= title %></h1>
    <span class="text-sm text-zinc-500"><%= bds.length %> tome<%= bds.length !== 1 ? 's' : '' %></span>
  </div>

  <!-- Filters -->
  <div class="flex flex-col sm:flex-row flex-wrap gap-3 mb-6">
    <input type="text" id="search-input" placeholder="Rechercher titre, série ou tag..."
           class="bg-zinc-900 border border-zinc-700 rounded px-3 py-2 text-sm text-zinc-200 placeholder-zinc-500 focus:outline-none focus:border-amber-600 w-full sm:w-64">
    <div class="flex gap-3 flex-wrap">
      <select id="filter-serie" class="bg-zinc-900 border border-zinc-700 rounded px-3 py-2 text-sm text-zinc-200 focus:outline-none focus:border-amber-600 flex-1 sm:flex-none">
        <option value="">Toutes les séries</option>
        <% for (const s of series) { %>
          <option value="<%= s %>"><%= s %></option>
        <% } %>
      </select>
      <select id="filter-status" class="bg-zinc-900 border border-zinc-700 rounded px-3 py-2 text-sm text-zinc-200 focus:outline-none focus:border-amber-600 flex-1 sm:flex-none">
        <option value="">Tous les statuts</option>
        <% for (const s of statuses) { %>
          <option value="<%= s.value %>"><%= s.label %></option>
        <% } %>
      </select>
      <% if (tags.length > 0) { %>
        <select id="filter-tag" class="bg-zinc-900 border border-zinc-700 rounded px-3 py-2 text-sm text-zinc-200 focus:outline-none focus:border-amber-600 flex-1 sm:flex-none">
          <option value="">Tous les tags</option>
          <% for (const t of tags) { %>
            <option value="<%= t %>"><%= t %></option>
          <% } %>
        </select>
      <% } %>
    </div>
  </div>

  <% if (bds.length === 0) { %>
    <p class="text-zinc-500 text-center py-12">Aucune BD ici pour l'instant.</p>
  <% } else { %>

    <!-- Pagination info -->
    <div class="flex items-center justify-between mb-3">
      <p id="showing-count" class="text-xs text-zinc-500"></p>
      <div class="flex items-center gap-2" id="pagination-controls"></div>
    </div>

    <!-- Desktop: table -->
    <div class="hidden md:block overflow-x-auto">
      <table class="w-full text-sm" id="bd-table">
        <thead>
          <tr class="text-left text-zinc-500 border-b border-zinc-800">
            <th class="pb-2 pr-4 w-12"></th>
            <th class="pb-2 pr-4 cursor-pointer hover:text-zinc-300 select-none" data-sort="serie">Série <span class="sort-icon"></span></th>
            <th class="pb-2 pr-4 cursor-pointer hover:text-zinc-300 select-none" data-sort="titre">Titre <span class="sort-icon"></span></th>
            <th class="pb-2 pr-4 w-16 text-center cursor-pointer hover:text-zinc-300 select-none" data-sort="numero">N° <span class="sort-icon"></span></th>
            <th class="pb-2 pr-4">Statut</th>
            <th class="pb-2 pr-4">Tags</th>
            <th class="pb-2 pr-4 w-12">Lien</th>
            <th class="pb-2 w-32"></th>
          </tr>
        </thead>
        <tbody>
          <% for (const bd of bds) { %>
            <tr class="bd-row border-b border-zinc-800/50 hover:bg-zinc-900/50 transition-colors"
                data-serie="<%= bd.serie %>"
                data-status="<%= bd.status %>"
                data-tags="<%= (bd.tags || []).join(',') %>"
                data-search="<%= (bd.serie + ' ' + bd.titre + ' ' + (bd.tags || []).join(' ')).toLowerCase() %>"
                data-sort-serie="<%= bd.serie.toLowerCase() %>"
                data-sort-titre="<%= bd.titre.toLowerCase() %>"
                data-sort-numero="<%= bd.numero != null ? bd.numero : 99999 %>">
              <td class="py-2 pr-3">
                <% if (bd.cover_url) { %>
                  <img src="<%= bd.cover_url %>" alt="" class="w-10 h-14 object-cover rounded shadow-sm" loading="lazy">
                <% } else { %>
                  <div class="w-10 h-14 bg-zinc-800 rounded flex items-center justify-center">
                    <svg class="w-5 h-5 text-zinc-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
                  </div>
                <% } %>
              </td>
              <td class="py-2.5 pr-4 text-zinc-300 font-medium"><%= bd.serie %></td>
              <td class="py-2.5 pr-4 text-zinc-200"><%= bd.titre %></td>
              <td class="py-2.5 pr-4 text-center text-zinc-400"><%= bd.numero != null ? bd.numero : '' %></td>
              <td class="py-2.5 pr-4">
                <select class="status-select bg-transparent border border-zinc-700 rounded px-2 py-1 text-xs focus:outline-none focus:border-amber-600
                  <%= bd.status === 'owned' || bd.status === 'owned_no_hs' ? 'text-emerald-400' : '' %>
                  <%= bd.status === 'missing' ? 'text-red-400' : '' %>
                  <%= bd.status === 'in_progress' ? 'text-amber-400' : '' %>
                  <%= bd.status === 'not_owned' ? 'text-zinc-500' : '' %>"
                  data-id="<%= bd.id %>">
                  <% for (const s of statuses) { %>
                    <option value="<%= s.value %>" <%= bd.status === s.value ? 'selected' : '' %>><%= s.label %></option>
                  <% } %>
                </select>
              </td>
              <td class="py-2.5 pr-4">
                <% if (bd.tags && bd.tags.length > 0) { %>
                  <div class="flex flex-wrap gap-1">
                    <% for (const tag of bd.tags) { %>
                      <span class="px-1.5 py-0.5 bg-zinc-800 rounded text-xs text-zinc-400"><%= tag %></span>
                    <% } %>
                  </div>
                <% } %>
              </td>
              <td class="py-2.5 pr-4 text-center">
                <% if (bd.web_tracking) { %>
                  <a href="<%= bd.web_tracking %>" target="_blank" rel="noopener" class="text-amber-500 hover:text-amber-400" title="Suivi web">&#8599;</a>
                <% } %>
              </td>
              <td class="py-2.5 text-right whitespace-nowrap">
                <a href="/edit/<%= bd.id %>" class="text-zinc-500 hover:text-zinc-300 text-xs mr-1">Modifier</a>
                <form method="POST" action="/duplicate/<%= bd.id %>" class="inline">
                  <button type="submit" class="text-zinc-500 hover:text-zinc-300 text-xs mr-1" title="Dupliquer">Dupli.</button>
                </form>
                <button class="btn-delete text-red-600 hover:text-red-400 text-xs" data-id="<%= bd.id %>" data-titre="<%= bd.titre %>">Suppr.</button>
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>

    <!-- Mobile: cards -->
    <div class="md:hidden space-y-3">
      <% for (const bd of bds) { %>
        <div class="bd-row bg-zinc-900/50 border border-zinc-800 rounded-lg p-3 flex gap-3"
             data-serie="<%= bd.serie %>"
             data-status="<%= bd.status %>"
             data-tags="<%= (bd.tags || []).join(',') %>"
             data-search="<%= (bd.serie + ' ' + bd.titre + ' ' + (bd.tags || []).join(' ')).toLowerCase() %>"
             data-sort-serie="<%= bd.serie.toLowerCase() %>"
             data-sort-titre="<%= bd.titre.toLowerCase() %>"
             data-sort-numero="<%= bd.numero != null ? bd.numero : 99999 %>">
          <div class="flex-shrink-0">
            <% if (bd.cover_url) { %>
              <img src="<%= bd.cover_url %>" alt="" class="w-14 h-20 object-cover rounded shadow" loading="lazy">
            <% } else { %>
              <div class="w-14 h-20 bg-zinc-800 rounded flex items-center justify-center">
                <svg class="w-6 h-6 text-zinc-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
              </div>
            <% } %>
          </div>
          <div class="flex-1 min-w-0">
            <div class="flex items-start justify-between gap-2">
              <div class="min-w-0">
                <p class="text-sm font-medium text-zinc-200 truncate"><%= bd.titre %></p>
                <p class="text-xs text-zinc-400"><%= bd.serie %><%= bd.numero != null ? ' #' + bd.numero : '' %></p>
              </div>
              <div class="flex items-center gap-1.5 flex-shrink-0">
                <% if (bd.web_tracking) { %>
                  <a href="<%= bd.web_tracking %>" target="_blank" rel="noopener" class="text-amber-500 text-sm">&#8599;</a>
                <% } %>
                <a href="/edit/<%= bd.id %>" class="text-zinc-500 text-xs">Modifier</a>
              </div>
            </div>
            <% if (bd.tags && bd.tags.length > 0) { %>
              <div class="flex flex-wrap gap-1 mt-1">
                <% for (const tag of bd.tags) { %>
                  <span class="px-1.5 py-0.5 bg-zinc-800 rounded text-xs text-zinc-500"><%= tag %></span>
                <% } %>
              </div>
            <% } %>
            <div class="mt-2 flex items-center gap-2">
              <select class="status-select bg-transparent border border-zinc-700 rounded px-2 py-1 text-xs focus:outline-none focus:border-amber-600
                <%= bd.status === 'owned' || bd.status === 'owned_no_hs' ? 'text-emerald-400' : '' %>
                <%= bd.status === 'missing' ? 'text-red-400' : '' %>
                <%= bd.status === 'in_progress' ? 'text-amber-400' : '' %>
                <%= bd.status === 'not_owned' ? 'text-zinc-500' : '' %>"
                data-id="<%= bd.id %>">
                <% for (const s of statuses) { %>
                  <option value="<%= s.value %>" <%= bd.status === s.value ? 'selected' : '' %>><%= s.label %></option>
                <% } %>
              </select>
              <button class="btn-delete text-red-600 hover:text-red-400 text-xs" data-id="<%= bd.id %>" data-titre="<%= bd.titre %>">Suppr.</button>
            </div>
          </div>
        </div>
      <% } %>
    </div>

  <% } %>
</main>

<!-- Delete confirmation modal -->
<div id="delete-modal" class="hidden fixed inset-0 z-[60] flex items-center justify-center bg-black/60 backdrop-blur-sm">
  <div class="bg-zinc-900 border border-zinc-700 rounded-lg p-6 mx-4 max-w-sm w-full shadow-xl">
    <h3 class="text-zinc-100 font-medium mb-2">Supprimer cette BD ?</h3>
    <p class="text-sm text-zinc-400 mb-4">&laquo; <span id="delete-modal-titre"></span> &raquo; sera définitivement supprimée.</p>
    <div class="flex justify-end gap-3">
      <button id="delete-cancel" class="px-4 py-2 text-sm text-zinc-400 hover:text-zinc-200 rounded hover:bg-zinc-800 transition-colors">Annuler</button>
      <button id="delete-confirm" class="px-4 py-2 text-sm bg-red-600 hover:bg-red-500 text-white rounded transition-colors">Supprimer</button>
    </div>
  </div>
</div>

<%- include('partials/foot') %>
