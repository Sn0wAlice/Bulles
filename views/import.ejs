<%- include('partials/head') %>
<%- include('partials/nav') %>

<main class="max-w-4xl mx-auto px-6 lg:px-12 py-8 flex-1">
  <h1 class="text-2xl lg:text-3xl font-bold text-zinc-100 mb-8"><%= title %></h1>

  <% if (result) { %>
    <% if (result.error) { %>
      <div class="bg-red-900/30 border border-red-800 text-red-300 rounded-xl px-5 py-4 mb-8 text-base">
        <%= result.error %>
      </div>
    <% } else { %>
      <div class="bg-emerald-900/30 border border-emerald-800 text-emerald-300 rounded-xl px-5 py-4 mb-8 text-base">
        <%= result.count %> BD<%= result.count !== 1 ? 's' : '' %> importée<%= result.count !== 1 ? 's' : '' %> avec succès.
      </div>
    <% } %>
  <% } %>

  <!-- Import -->
  <div class="bg-zinc-900/50 border border-zinc-800 rounded-xl p-6 lg:p-8 mb-8">
    <h2 class="text-base lg:text-lg font-medium text-zinc-200 mb-4">Importer depuis Notion</h2>
    <p class="text-base text-zinc-400 mb-6">
      Colonnes attendues : <code class="text-zinc-300">Name</code>, <code class="text-zinc-300">Titre</code>,
      <code class="text-zinc-300">Numéro</code>, <code class="text-zinc-300">Status</code>,
      <code class="text-zinc-300">Commentaire</code>, <code class="text-zinc-300">Web traking</code>.
    </p>

    <form method="POST" action="/import" enctype="multipart/form-data" class="space-y-5">
      <div>
        <input type="file" name="csvfile" accept=".csv"
               class="text-base text-zinc-400 file:mr-4 file:py-2.5 file:px-5 file:rounded-lg file:border-0 file:text-base file:bg-zinc-800 file:text-zinc-300 hover:file:bg-zinc-700 file:cursor-pointer file:transition-colors">
      </div>
      <button type="submit" class="px-6 py-3 bg-amber-600 hover:bg-amber-500 text-white rounded-lg text-base font-medium transition-colors">
        Importer
      </button>
    </form>
  </div>

  <!-- Export -->
  <div class="bg-zinc-900/50 border border-zinc-800 rounded-xl p-6 lg:p-8">
    <h2 class="text-base lg:text-lg font-medium text-zinc-200 mb-4">Exporter ma collection</h2>
    <p class="text-base text-zinc-400 mb-6">Téléchargez votre collection complète pour backup ou migration.</p>
    <div class="flex flex-wrap gap-4">
      <a href="/export/csv" class="px-6 py-3 bg-zinc-800 hover:bg-zinc-700 text-zinc-200 rounded-lg text-base transition-colors">
        Exporter CSV
      </a>
      <a href="/export/json" class="px-6 py-3 bg-zinc-800 hover:bg-zinc-700 text-zinc-200 rounded-lg text-base transition-colors">
        Exporter JSON
      </a>
    </div>
  </div>
</main>

<%- include('partials/foot') %>
